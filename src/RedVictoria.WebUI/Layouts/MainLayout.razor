@inherits LayoutComponentBase
@inject IAuthSessionService AuthSessionService
@inject NavigationManager Navigation

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" >
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Dark"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudImage Src="image/logo.png"
                  Alt="Logo RedVictoria"
                  Class="ml-2 rv-appbar-logo"
                  Height="32"
                  Width="120"
                  ObjectFit="ObjectFit.Contain"
                  Style="height:32px; max-height:32px; width:auto; max-width:120px; object-fit:contain; display:block;" />
        <MudSpacer />
        @if (_isAuthenticated)
        {
            <MudButton Href="@AppRoutes.Dashboard"
                       Color="Color.Inherit"
                       Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.Dashboard">
                Dashboard
            </MudButton>
            <MudButton Color="Color.Inherit"
                       Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.Logout"
                       OnClick="LogoutAsync">
                Cerrar sesión
            </MudButton>
        }
        else
        {
            <MudButton Href="@AppRoutes.Login"
                       Color="Color.Inherit"
                       Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.Login">
                Iniciar sesión
            </MudButton>
        }
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always"
               Elevation="0"
               Class="rv-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.False" Class="py-6 px-4 px-md-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        var session = await AuthSessionService.GetSessionAsync();
        _isAuthenticated = session?.IsValid == true;
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task LogoutAsync()
    {
        await AuthSessionService.ClearSessionAsync();
        _isAuthenticated = false;
        Navigation.NavigateTo(AppRoutes.Login, replace: true);
    }
}
