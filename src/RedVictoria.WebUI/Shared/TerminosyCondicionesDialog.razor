<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                <MudIcon Icon="@Icons.Material.Filled.PrivacyTip" />
            </MudAvatar>
            <MudText Typo="Typo.h6">Autorización para el Tratamiento de Datos Personales</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="terminos-dialog-content">
            <MudText Typo="Typo.body2">
                Autorizo de manera previa, expresa e informada a El Equipo Ganador para recolectar,
                almacenar, consultar, usar, actualizar y tratar mis datos personales suministrados en
                este formulario, incluyendo mi tipo y número de documento, nombres, apellidos, datos
                de contacto, ubicación y demás información registrada, con la finalidad de gestionar
                mi inscripción en la plataforma, validar mi participación dentro de la red ciudadana,
                administrar mi relación con la plataforma, generar reportes internos, permitir el
                seguimiento de referidos y cumplir con las finalidades propias del sistema.
            </MudText>
            <MudText Typo="Typo.body2">
                Declaro que la información suministrada es veraz, completa y actualizada. Reconozco
                que puedo ejercer mis derechos a conocer, actualizar, rectificar, solicitar la
                eliminacion de mis datos y revocar la autorización cuando sea procedente, conforme a
                la legislación colombiana de protección de datos personales.
            </MudText>
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                Al aceptar, manifiesto que he leído y comprendido esta autorización y autorizo el
                tratamiento de mis datos personales para las finalidades descritas.
            </MudAlert>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Default" Variant="Variant.Text" OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Check" OnClick="Accept">
            Aceptar términos
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private void Cancel() => MudDialog.Cancel();

    private void Accept() => MudDialog.Close(DialogResult.Ok(true));
}
