<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                <MudIcon Icon="@Icons.Material.Filled.PrivacyTip" />
            </MudAvatar>
            <MudText Typo="Typo.h6">Autorizacion para el Tratamiento de Datos Personales</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="terminos-dialog-content">
            <MudText Typo="Typo.body2">
                Autorizo de manera previa, expresa e informada a El Equipo Ganador para recolectar,
                almacenar, consultar, usar, actualizar y tratar mis datos personales suministrados en
                este formulario, incluyendo mi tipo y numero de documento, nombres, apellidos, datos
                de contacto, ubicacion y demas informacion registrada, con la finalidad de gestionar
                mi inscripcion en la plataforma, validar mi participacion dentro de la red ciudadana,
                administrar mi relacion con la plataforma, generar reportes internos, permitir el
                seguimiento de referidos y cumplir con las finalidades propias del sistema.
            </MudText>
            <MudText Typo="Typo.body2">
                Declaro que la informacion suministrada es veraz, completa y actualizada. Reconozco
                que puedo ejercer mis derechos a conocer, actualizar, rectificar, solicitar la
                eliminacion de mis datos y revocar la autorizacion cuando sea procedente, conforme a
                la legislacion colombiana de proteccion de datos personales.
            </MudText>
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                Al aceptar, manifiesto que he leido y comprendido esta autorizacion y autorizo el
                tratamiento de mis datos personales para las finalidades descritas.
            </MudAlert>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Default" Variant="Variant.Text" OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Check" OnClick="Accept">
            Aceptar terminos
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private void Cancel() => MudDialog.Cancel();

    private void Accept() => MudDialog.Close(DialogResult.Ok(true));
}
