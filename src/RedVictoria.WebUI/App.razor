    {
        PaletteLight = new PaletteLight
        {
            Primary = "#0443FF",
            PrimaryContrastText = "#FFFFFF",
            Secondary = "#475569",
            SecondaryContrastText = "#FFFFFF",
            Tertiary = "#E8EEFF",
            Info = "#2563EB",
            Success = "#1D4ED8",
            Warning = "#7C3AED",
            Error = "#DC2626",
            Background = "#F4F7FF",
            Surface = "#FFFFFF",
            AppbarBackground = "#0443FF",
            AppbarText = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#0F172A",
            DrawerIcon = "#0443FF",
            TextPrimary = "#0F172A",
            TextSecondary = "#526174",
            LinesDefault = "#D9E2F7",
            TableLines = "#E3EAFB",
            TableStriped = "#F7F9FF",
            TableHover = "#EEF3FF",
            ActionDefault = "#0443FF",
            ActionDisabled = "#94A3B8",
            ActionDisabledBackground = "#E7ECF8"
        },
