@page "/registro-ciudadano"
@page "/registro-ciudadano/{CodigoReferido}"
@layout RegistroCiudadanoLayout
@using System.Globalization
@inject RegistroCiudadanoViewModel ViewModel
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ILogger<RegistroCiudadano> Logger

<PageTitle>Registro ciudadano</PageTitle>

<MudOverlay Visible="@ViewModel.IsBusy"
            DarkBackground="true"
            AutoClose="false"
            >
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="3" >
        <MudProgressCircular Indeterminate="true"
                             Color="Color.Primary"
                             Size="Size.Large"
                             StrokeWidth="4" />
        <MudText Typo="Typo.h6" Align="Align.Center">@LoadingMessage</MudText>
        <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
            Por favor espera un momento.
        </MudText>
    </MudStack>
</MudOverlay>

<div style="width:100%; max-width:1200px; margin:0 auto; padding:16px; box-sizing:border-box;">
    <MudStack Spacing="4" >
        <div style="width:100%; margin-bottom:18px; padding:22px; border-radius:18px; background:linear-gradient(135deg, #0443FF 0%, #002DB3 100%); box-shadow:0 16px 36px rgba(4,67,255,0.24); box-sizing:border-box;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" >
                <MudAvatar Color="Color.Default" Variant="Variant.Filled" >
                    <MudIcon Icon="@Icons.Material.Filled.HowToVote" />
                </MudAvatar>
                <div style="min-width:0; color:#ffffff;">
                    <MudText Typo="Typo.h4" >Registro ciudadano</MudText>
                    <MudText Typo="Typo.body2" >
                        Completa tus datos para sumarte a la red de participación de El Equipo Ganador.
                    </MudText>
                </div>
            </MudStack>
        </div>

        <MudForm @ref="_form" >
            <MudGrid Spacing="3" >
                <MudItem xs="12" lg="8">
                    <div style="width:100%; padding:20px; border-radius:18px; background:#ffffff; box-shadow:0 12px 35px rgba(15,23,42,0.08); border:1px solid rgba(226,232,240,0.9); box-sizing:border-box;">
                        <div style="display:flex; align-items:center; gap:12px; margin-bottom:18px; min-width:0;">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" >
                                <MudIcon Icon="@Icons.Material.Filled.Badge" />
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle1" >Datos personales</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Información básica para identificar tu registro.</MudText>
                            </div>
                        </div>

                        <MudGrid Spacing="2" >
                            <MudItem xs="12">
                                <MudTextField @bind-Value="ViewModel.Request.NombresCompletos"
                                              Label="Nombres completos"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Required="true"
                                              Immediate="true"
                                              Disabled="@ViewModel.IsBusy"
                                              MaxLength="200"
                                              
                                              Validation="@(new Func<string?, IEnumerable<string>>(ViewModel.ValidateNombresCompletos))" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudDatePicker @bind-Date="ViewModel.Request.FechaNacimiento"
                                               Label="Fecha de nacimiento"
                                               Placeholder="Seleccione la fecha"
                                               DateFormat="dd/MM/yyyy"
                                               Culture="@ColombiaCulture"
                                               PickerVariant="PickerVariant.Dialog"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Required="true"
                                               RequiredError="Fecha de nacimiento es obligatoria."
                                               Disabled="@ViewModel.IsBusy"
                                               MaxDate="@DateTime.Today"
                                               
                                               Validation="@(new Func<DateTime?, IEnumerable<string>>(ViewModel.ValidateFechaNacimiento))" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudAutocomplete T="int?"
                                                 Label="Departamento de nacimiento"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense"
                                                 Dense="true"
                                                 Clearable="true"
                                                 Required="true"
                                                 RequiredError="Departamento de nacimiento es obligatorio."
                                                 Value="@ViewModel.Request.DepartamentoId"
                                                 ValueChanged="@ViewModel.OnDepartamentoChangedAsync"
                                                 Disabled="@ViewModel.IsBusy"
                                                 SearchFunc="SearchDepartamentosAsync"
                                                 ToStringFunc="GetDepartamentoText"
                                                 MaxItems="null"
                                                 MinCharacters="0"
                                                 ResetValueOnEmptyText="true"
                                                 Strict="false"
                                                  />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudAutocomplete T="int?"
                                                 Label="Ciudad de nacimiento"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense"
                                                 Dense="true"
                                                 Clearable="true"
                                                 Required="true"
                                                 RequiredError="Ciudad de nacimiento es obligatoria."
                                                 Disabled="@(!ViewModel.PuedeSeleccionarCiudad || ViewModel.IsBusy)"
                                                 @bind-Value="ViewModel.Request.MunicipioId"
                                                 SearchFunc="SearchCiudadesAsync"
                                                 ToStringFunc="GetCiudadText"
                                                 MaxItems="null"
                                                 MinCharacters="0"
                                                 ResetValueOnEmptyText="true"
                                                 Strict="false"
                                                  />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudSelect T="int?" @bind-Value="ViewModel.Request.ParametroIdTipoIdentificacion"
                                           Disabled="@ViewModel.IsBusy"
                                           Label="Tipo de identificación"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           Required="true"
                                           RequiredError="Tipo de identificación es obligatorio."
                                           >
                                    @foreach (var opcion in ViewModel.Parametros.TiposIdentificacion)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)opcion.ParametroId)">@opcion.Descripcion</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="ViewModel.Request.NumeroIdentificacion"
                                              Disabled="@ViewModel.IsBusy"
                                              Label="Número de identificación"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Required="true"
                                              Immediate="true"
                                              MaxLength="50"
                                              
                                              Validation="@(new Func<string?, IEnumerable<string>>(ViewModel.ValidateNumeroIdentificacion))" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudSelect T="int?" @bind-Value="ViewModel.Request.ParametroIdGenero"
                                           Disabled="@ViewModel.IsBusy"
                                           Label="Género"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           Required="true"
                                           RequiredError="Género es obligatorio."
                                           >
                                    @foreach (var opcion in ViewModel.Parametros.Generos.OrderBy(x => x.ParametroId))
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)opcion.ParametroId)">@opcion.Descripcion</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudSelect T="int?" @bind-Value="ViewModel.Request.ParametroIdSoy"
                                           Disabled="@ViewModel.IsBusy"
                                           Label="Soy"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           Required="true"
                                           RequiredError="Soy es obligatorio."
                                           >
                                    @foreach (var opcion in ViewModel.Parametros.Soy)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)opcion.ParametroId)">@opcion.Descripcion</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect T="int?" @bind-Value="ViewModel.Request.ParametroIdTipoDiscapacidad"
                                           Disabled="@ViewModel.IsBusy"
                                           Label="Tipo de discapacidad"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           Required="true"
                                           RequiredError="Tipo de discapacidad es obligatorio."
                                           >
                                    @foreach (var opcion in ViewModel.Parametros.TiposDiscapacidad.OrderByDescending(x => x.ParametroId))
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)opcion.ParametroId)">@opcion.Descripcion</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudSelect T="int?" @bind-Value="ViewModel.Request.ParametroIdEstadoCivil"
                                           Disabled="@ViewModel.IsBusy"
                                           Label="Estado civil"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           Required="true"
                                           RequiredError="Estado civil es obligatorio."
                                           >
                                    @foreach (var opcion in ViewModel.Parametros.EstadosCivil)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)opcion.ParametroId)">@opcion.Descripcion</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudSelect T="bool?"
                                           Value="@ViewModel.Request.TieneHijos"
                                           ValueChanged="@ViewModel.OnTieneHijosChanged"
                                           Disabled="@ViewModel.IsBusy"
                                           Label="Tiene hijos"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           Required="true"
                                           RequiredError="Indica si tiene hijos."
                                           >
                                    <MudSelectItem T="bool?" Value="true">Si</MudSelectItem>
                                    <MudSelectItem T="bool?" Value="false">No</MudSelectItem>
                                </MudSelect>
                            </MudItem>

                            @if (ViewModel.Request.TieneHijos == true)
                            {
                                <MudItem xs="12" sm="6">
                                    <MudTextField T="int?"
                                                  @bind-Value="ViewModel.Request.Cuantos"
                                                  Disabled="@ViewModel.IsBusy"
                                                  InputType="InputType.Number"
                                                  Label="Cuantos"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Required="true"
                                                  Immediate="true"
                                                  
                                                  Validation="@(new Func<int?, IEnumerable<string>>(ViewModel.ValidateCuantos))" />
                                </MudItem>
                            }

                            <MudItem xs="12" sm="6">
                                <MudSelect T="bool?"
                                           Value="@ViewModel.Request.TieneVehiculo"
                                           ValueChanged="@ViewModel.OnTieneVehiculoChanged"
                                           Disabled="@ViewModel.IsBusy"
                                           Label="Tiene vehiculo"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           Required="true"
                                           RequiredError="Indica si tiene vehiculo."
                                           >
                                    <MudSelectItem T="bool?" Value="true">Si</MudSelectItem>
                                    <MudSelectItem T="bool?" Value="false">No</MudSelectItem>
                                </MudSelect>
                            </MudItem>

                            @if (ViewModel.Request.TieneVehiculo == true)
                            {
                                <MudItem xs="12" sm="6">
                                    <MudSelect T="int?" @bind-Value="ViewModel.Request.ParametroIdTipoVehiculo"
                                               Disabled="@ViewModel.IsBusy"
                                               Label="Tipo de vehiculo"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Dense="true"
                                               Clearable="true"
                                               Required="true"
                                               RequiredError="Tipo de vehiculo es obligatorio."
                                               >
                                        @foreach (var opcion in ViewModel.Parametros.TiposVehiculo)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)opcion.ParametroId)">@opcion.Descripcion</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                            }

                            <MudItem xs="12" sm="6">
                                <MudSelect T="int?" @bind-Value="ViewModel.Request.ParametroIdReligion"
                                           Disabled="@ViewModel.IsBusy"
                                           Label="Religion"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           Required="true"
                                           RequiredError="Religion es obligatoria."
                                           >
                                    @foreach (var opcion in ViewModel.Parametros.Religiones)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)opcion.ParametroId)">@opcion.Descripcion</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudSelect T="bool?" @bind-Value="ViewModel.Request.EsEmpleado"
                                           Disabled="@ViewModel.IsBusy"
                                           Label="Es empleado"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           Required="true"
                                           RequiredError="Indica si es empleado."
                                           >
                                    <MudSelectItem T="bool?" Value="true">Si</MudSelectItem>
                                    <MudSelectItem T="bool?" Value="false">No</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudItem>

                <MudItem xs="12" lg="4">
                    <div style="width:100%; padding:20px; border-radius:18px; background:#ffffff; box-shadow:0 12px 35px rgba(15,23,42,0.08); border:1px solid rgba(226,232,240,0.9); box-sizing:border-box;">
                        <div style="display:flex; align-items:center; gap:12px; margin-bottom:18px; min-width:0;">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" >
                                <MudIcon Icon="@Icons.Material.Filled.ContactPhone" />
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle1" >Contacto y ubicación</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Canales para mantener comunicación contigo.</MudText>
                            </div>
                        </div>

                        <MudGrid Spacing="2" >
                            <MudItem xs="12">
                                <MudTextField @bind-Value="ViewModel.Request.Email"
                                              Disabled="@ViewModel.IsBusy"
                                              Label="Email"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Required="true"
                                              Immediate="true"
                                              MaxLength="150"
                                              
                                              Validation="@(new Func<string?, IEnumerable<string>>(ViewModel.ValidateEmail))" />
                            </MudItem>

                            <MudItem xs="12" sm="6" lg="12">
                                <MudTextField @bind-Value="ViewModel.Request.Celular"
                                              Disabled="@ViewModel.IsBusy"
                                              Label="Celular 1"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Required="true"
                                              Immediate="true"
                                              MaxLength="30"
                                              
                                              Validation="@(new Func<string?, IEnumerable<string>>(ViewModel.ValidateCelular))" />
                            </MudItem>

                            <MudItem xs="12" sm="6" lg="12">
                                <MudSelect T="bool?" @bind-Value="ViewModel.Request.TieneWhatsapp"
                                           Disabled="@ViewModel.IsBusy"
                                           Label="Celular 1 tiene WhatsApp"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           Required="true"
                                           RequiredError="Indica si el celular 1 tiene WhatsApp."
                                           >
                                    <MudSelectItem T="bool?" Value="true">Si</MudSelectItem>
                                    <MudSelectItem T="bool?" Value="false">No</MudSelectItem>
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" sm="6" lg="12">
                                <MudTextField T="string"
                                              Value="@ViewModel.Request.Celular2"
                                              ValueChanged="@((string? value) => ViewModel.OnCelular2Changed(value))"
                                              Disabled="@ViewModel.IsBusy"
                                              Label="Celular 2"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Immediate="true"
                                              MaxLength="30"
                                              
                                              Validation="@(new Func<string?, IEnumerable<string>>(ViewModel.ValidateCelular2))" />
                            </MudItem>

                            <MudItem xs="12" sm="6" lg="12">
                                <MudSelect T="bool?" @bind-Value="ViewModel.Request.TieneWhatsapp2"
                                           Disabled="@(ViewModel.IsBusy || string.IsNullOrWhiteSpace(ViewModel.Request.Celular2))"
                                           Label="Celular 2 tiene WhatsApp"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           >
                                    <MudSelectItem T="bool?" Value="true">Si</MudSelectItem>
                                    <MudSelectItem T="bool?" Value="false">No</MudSelectItem>
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" sm="6" lg="12">
                                <MudSelect T="int?" @bind-Value="ViewModel.Request.ParametroIdDondeVive"
                                           Disabled="@ViewModel.IsBusy"
                                           Label="Donde vive"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           Required="true"
                                           RequiredError="Donde vive es obligatorio."
                                           >
                                    @foreach (var opcion in ViewModel.Parametros.DondeVive)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)opcion.ParametroId)">@opcion.Descripcion</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12">
                                <MudAutocomplete T="int?" @bind-Value="ViewModel.Request.ParametroIdVereda"
                                                 Disabled="@ViewModel.IsBusy"
                                                 Label="Centro Poblado"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense"
                                                 Dense="true"
                                                 Clearable="true"
                                                 Required="true"
                                                 RequiredError="Vereda es obligatoria."
                                                 SearchFunc="SearchVeredasAsync"
                                                 ToStringFunc="GetVeredaText"
                                                 MaxItems="null"
                                                 MinCharacters="0"
                                                 ResetValueOnEmptyText="true"
                                                 Strict="false"
                                                  />
                            </MudItem>

                            <MudItem xs="12" sm="6" lg="12">
                                <MudTextField @bind-Value="ViewModel.Request.Direccion"
                                              Disabled="@ViewModel.IsBusy"
                                              Label="Dirección"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Required="true"
                                              Immediate="true"
                                              MaxLength="250"
                                               />
                            </MudItem>

                        </MudGrid>
                    </div>
                </MudItem>

                <MudItem xs="12">
                    <div style="width:100%; padding:20px; border-radius:18px; background:#ffffff; box-shadow:0 12px 35px rgba(15,23,42,0.08); border:1px solid rgba(226,232,240,0.9); box-sizing:border-box;">
                        <MudGrid Spacing="2" >

                            <MudItem xs="12">
                                <div style="display:flex; align-items:center; gap:12px; margin-bottom:18px; min-width:0;">
                                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled" >
                                        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" />
                                    </MudAvatar>
                                    <div>
                                        <MudText Typo="Typo.subtitle1" >Referido y acceso</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            Establece una contraseña para gestionar y consultar tu red de simpatizantes.
                                        </MudText>
                                    </div>
                                </div>
                            </MudItem>

                            <MudItem xs="12">
                                <MudSwitch T="bool"
                                           Disabled="@ViewModel.IsBusy"
                                           Value="@ViewModel.Request.TieneAcceso"
                                           ValueChanged="@ViewModel.ToggleTieneAcceso"
                                           Color="Color.Primary"
                                           
                                           Label="Crear acceso de usuario" />
                            </MudItem>

                            @if (ViewModel.Request.TieneAcceso)
                            {
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="ViewModel.Request.Password"
                                                  Disabled="@ViewModel.IsBusy"
                                                  Label="Contraseña"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  InputType="InputType.Password"
                                                  Required="@ViewModel.Request.TieneAcceso"
                                                  Immediate="true"
                                                  
                                                  Validation="@(new Func<string?, IEnumerable<string>>(ViewModel.ValidatePasswordField))" />
                                </MudItem>

                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="ViewModel.Request.ConfirmPassword"
                                                  Disabled="@ViewModel.IsBusy"
                                                  Label="Confirmar contraseña"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  InputType="InputType.Password"
                                                  Required="@ViewModel.Request.TieneAcceso"
                                                  Immediate="true"
                                                  
                                                  Validation="@(new Func<string?, IEnumerable<string>>(ViewModel.ValidateConfirmPasswordField))" />
                                </MudItem>
                            }
                        </MudGrid>
                    </div>
                </MudItem>

                <MudItem xs="12">
                    <div style="width:100%; padding:20px; border-radius:18px; background:#ffffff; box-shadow:0 12px 35px rgba(15,23,42,0.08); border:1px solid rgba(226,232,240,0.9); box-sizing:border-box;">
                        <div style="display:flex; align-items:center; gap:12px; margin-bottom:18px; min-width:0;">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" >
                                <MudIcon Icon="@Icons.Material.Filled.Article" />
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle1" >Términos y registro</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Revisa las condiciones y finaliza tu registro.</MudText>
                            </div>
                        </div>

                        <MudGrid Spacing="2" >
                            <MudItem xs="12" md="8">
                                <div style="width:100%; display:flex; align-items:flex-start; flex-wrap:wrap; gap:10px; box-sizing:border-box;">
                                    <MudCheckBox T="bool"
                                                 Value="@ViewModel.AceptaTerminos"
                                                 ValueChanged="OnAceptaTerminosChanged"
                                                 Disabled="@ViewModel.IsBusy"
                                                 Color="Color.Primary"
                                                 Required="true"
                                                 RequiredError="Debes aceptar los términos y condiciones."
                                                 >
                                        <ChildContent>
                                            <MudText Typo="Typo.body2" >
                                                Acepto los términos y condiciones
                                            </MudText>
                                        </ChildContent>
                                    </MudCheckBox>

                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Article"
                                               Disabled="@ViewModel.IsBusy"
                                               OnClick="OpenTerminosDialogAsync"
                                               >
                                        Leer términos y condiciones
                                    </MudButton>
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="4" >
                                <MudButton Color="Color.Primary"
                                           Variant="Variant.Filled"
                                           Size="Size.Medium"
                                           Disabled="@(!ViewModel.CanSubmit)"
                                           OnClick="HandleRegistroAsync"
                                           FullWidth="true">
                                    @if (ViewModel.IsSubmitting)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true"  />
                                        <span>Registrando...</span>
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.HowToReg"  />
                                        <span>Registrarme</span>
                                    }
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudStack>
</div>
@code {
    private MudForm? _form;
    private bool _showReferidoInvalidoAlert;
    private static readonly CultureInfo ColombiaCulture = CultureInfo.GetCultureInfo("es-CO");

    [Parameter]
    public string? CodigoReferido { get; set; }

    private string LoadingMessage
    {
        get
        {
            if (ViewModel.IsSubmitting)
            {
                return "Guardando registro...";
            }

            if (ViewModel.IsLoadingCiudades)
            {
                return "Cargando ciudades...";
            }

            return "Cargando información...";
        }
    }

    private Task<IEnumerable<int?>> SearchDepartamentosAsync(string? value, CancellationToken cancellationToken)
    {
        var items = ViewModel.Departamentos
            .Where(departamento => Matches(value, departamento.DepartamentoNombre, departamento.Descripcion))
            .Select(departamento => (int?)departamento.DepartamentoId);

        return Task.FromResult(items);
    }

    private Task<IEnumerable<int?>> SearchCiudadesAsync(string? value, CancellationToken cancellationToken)
    {
        var items = ViewModel.Ciudades
            .Where(ciudad => Matches(value, ciudad.CiudadNombre, ciudad.Descripcion))
            .Select(ciudad => (int?)ciudad.CiudadId);

        return Task.FromResult(items);
    }

    private Task<IEnumerable<int?>> SearchVeredasAsync(string? value, CancellationToken cancellationToken)
    {
        var items = ViewModel.Parametros.Veredas
            .Where(opcion => Matches(value, opcion.Descripcion))
            .Select(opcion => (int?)opcion.ParametroId);

        return Task.FromResult(items);
    }

    private string GetDepartamentoText(int? departamentoId) =>
        ViewModel.Departamentos.FirstOrDefault(departamento => departamento.DepartamentoId == departamentoId)?.DepartamentoNombre
        ?? string.Empty;

    private string GetCiudadText(int? ciudadId) =>
        ViewModel.Ciudades.FirstOrDefault(ciudad => ciudad.CiudadId == ciudadId)?.CiudadNombre
        ?? string.Empty;

    private string GetVeredaText(int? parametroId) =>
        ViewModel.Parametros.Veredas.FirstOrDefault(opcion => opcion.ParametroId == parametroId)?.Descripcion
        ?? string.Empty;

    private static bool Matches(string? search, params string?[] values) =>
        string.IsNullOrWhiteSpace(search)
        || values.Any(value => !string.IsNullOrWhiteSpace(value)
            && value.Contains(search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnParametersSetAsync()
    {
        await ViewModel.InitializeAsync(ResolveCodigoReferido());

        if (ViewModel.BloquearRegistroPorReferido)
        {
            _showReferidoInvalidoAlert = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_showReferidoInvalidoAlert)
        {
            _showReferidoInvalidoAlert = false;
            await ShowAlertAsync(
                "warning",
                "Referido inválido",
                "No puede continuar porque el referido ingresado no existe.");
        }
    }

    private string? ResolveCodigoReferido()
    {
        if (!string.IsNullOrWhiteSpace(CodigoReferido))
        {
            return CodigoReferido;
        }

        return GetQueryStringValue("codigoReferido") ?? GetQueryStringValue("ref");
    }

    private string? GetQueryStringValue(string key)
    {
        var query = Navigation.ToAbsoluteUri(Navigation.Uri).Query;
        if (string.IsNullOrWhiteSpace(query))
        {
            return null;
        }

        foreach (var pair in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = pair.Split('=', 2);
            var name = Uri.UnescapeDataString(parts[0]);

            if (!string.Equals(name, key, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            return parts.Length == 2
                ? Uri.UnescapeDataString(parts[1].Replace("+", " "))
                : string.Empty;
        }

        return null;
    }

    private async Task OpenTerminosDialogAsync()
    {
        var options = new DialogOptions
        {
            CloseButton = true,
            FullWidth = true,
            MaxWidth = MaxWidth.Medium
        };

        var dialog = await DialogService.ShowAsync<TerminosyCondicionesDialog>(
            "Términos y condiciones",
            options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is true)
        {
            ViewModel.AceptaTerminos = true;
        }
    }

    private void OnAceptaTerminosChanged(bool value)
    {
        ViewModel.AceptaTerminos = value;
    }

    private async Task HandleRegistroAsync()
    {
        if (ViewModel.IsBusy)
        {
            return;
        }

        if (!ViewModel.AceptaTerminos)
        {
            await ShowAlertAsync(
                "warning",
                "Términos y condiciones requeridos",
                "Para completar el registro debes leer y aceptar los términos y condiciones.");
            return;
        }

        if (_form is not null)
        {
            await _form.Validate();
            if (!_form.IsValid)
            {
                await ShowAlertAsync(
                    "warning",
                    "Formulario incompleto",
                    "Revisa los datos del formulario antes de guardar.");
                return;
            }
        }

        if (ViewModel.BloquearRegistroPorReferido)
        {
            await ShowAlertAsync(
                "warning",
                "Referido inválido",
                "No puede continuar porque el referido ingresado no existe.");
            return;
        }

        Logger.LogInformation(
            "Registro ciudadano Razor antes de guardar campos nuevos: ParametroIdTipoDiscapacidad={ParametroIdTipoDiscapacidad}, ParametroIdEstadoCivil={ParametroIdEstadoCivil}, TieneHijos={TieneHijos}, Cuantos={Cuantos}, TieneVehiculo={TieneVehiculo}, ParametroIdTipoVehiculo={ParametroIdTipoVehiculo}, ParametroIdReligion={ParametroIdReligion}, EsEmpleado={EsEmpleado}",
            ViewModel.Request.ParametroIdTipoDiscapacidad,
            ViewModel.Request.ParametroIdEstadoCivil,
            ViewModel.Request.TieneHijos,
            ViewModel.Request.Cuantos,
            ViewModel.Request.TieneVehiculo,
            ViewModel.Request.ParametroIdTipoVehiculo,
            ViewModel.Request.ParametroIdReligion,
            ViewModel.Request.EsEmpleado);

        var registrado = await ViewModel.RegistrarAsync();
        if (registrado)
        {
            if (!string.IsNullOrWhiteSpace(ViewModel.TerminosWarningMessage))
            {
                await ShowAlertAsync(
                    "warning",
                    "Registro exitoso con advertencia",
                    ViewModel.TerminosWarningMessage);
            }

            var referidoUrl = ViewModel.BuildReferralUrl(ViewModel.CodigoReferidoRegistrado);
            if (string.IsNullOrWhiteSpace(referidoUrl))
            {
                await ShowAlertAsync(
                    "error",
                    "Registro exitoso",
                    "El ciudadano fue registrado, pero no fue posible obtener el código referido generado.");
                return;
            }

            await ShowReferralLinkAlertAsync(referidoUrl);
            ViewModel.LimpiarFormulario();
            _form?.ResetValidation();
            return;
        }

        await ShowAlertAsync(
            "error",
            "No fue posible registrar",
            ViewModel.ErrorMessage ?? "No fue posible registrar el ciudadano.");
    }

    private ValueTask ShowAlertAsync(string icon, string title, string text) =>
        JSRuntime.InvokeVoidAsync("RedVictoriaSweetAlert.fire", icon, title, text);

    private ValueTask ShowReferralLinkAlertAsync(string url) =>
        JSRuntime.InvokeVoidAsync("RedVictoriaSweetAlert.fireReferralLink", url);
}
