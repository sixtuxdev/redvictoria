@page "/dashboard"
@using RedVictoria.WebUI.Helpers
@inject DashboardViewModel ViewModel
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Dashboard</PageTitle>

@if (ViewModel.IsLoading)
{
    <div class="dashboard-loading">
        <MudStack AlignItems="AlignItems.Center" Class="py-10">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">Cargando dashboard...</MudText>
        </MudStack>
    </div>
}
else
{
    <div class="dashboard-page">
        <MudStack Spacing="5" Class="dashboard-content">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="dashboard-header dashboard-hero">
                <div class="dashboard-heading">
                    <MudText Typo="Typo.h4" Class="dashboard-title">Dashboard</MudText>
                    <MudText Typo="Typo.body2" Class="dashboard-subtitle">
                        Hola, @ViewModel.Session?.Nombre. Esta es la actividad de tu red de simpatizantes.
                    </MudText>
                </div>
                <MudButton Color="Color.Primary"
                           Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           Disabled="@ViewModel.IsBusy"
                           OnClick="ReloadAsync"
                           Class="dashboard-refresh-button">
                    Actualizar
                </MudButton>
            </MudStack>

        @if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="dashboard-alert">
                @ViewModel.ErrorMessage
            </MudAlert>
        }

        <MudGrid Spacing="3" Class="dashboard-summary-grid">
            <MudItem xs="12" lg="4">
                <MudPaper Elevation="1" Class="pa-4 own-referral-card dashboard-panel">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Class="dashboard-card-avatar">
                                <MudIcon Icon="@Icons.Material.Filled.Share" />
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle1" Class="dashboard-card-title">Comparte tu referido</MudText>
                                <MudText Typo="Typo.caption" Class="dashboard-card-caption">
                                    Invita nuevos simpatizantes bajo tu red.
                                </MudText>
                            </div>
                        </MudStack>

                        <MudText Typo="Typo.body2" Class="own-referral-url">
                            @Display(ViewModel.MiUrlReferido)
                        </MudText>

                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Filled.ContentCopy"
                                   Disabled="@string.IsNullOrWhiteSpace(ViewModel.MiUrlReferido)"
                                   OnClick="CopyOwnReferralUrlAsync"
                                   Class="dashboard-primary-action">
                            Copiar mi enlace de referido
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" lg="2">
                <MudPaper Elevation="1" Class="pa-4 dashboard-summary summary-direct">
                    <MudText Typo="Typo.caption" Class="dashboard-summary-label">Referidos directos</MudText>
                    <MudText Typo="Typo.h4" Class="dashboard-summary-value">@ViewModel.TotalDirectos</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" lg="2">
                <MudPaper Elevation="1" Class="pa-4 dashboard-summary summary-indirect">
                    <MudText Typo="Typo.caption" Class="dashboard-summary-label">Referidos indirectos</MudText>
                    <MudText Typo="Typo.h4" Class="dashboard-summary-value">@ViewModel.TotalIndirectos</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" lg="2">
                <MudPaper Elevation="1" Class="pa-4 dashboard-summary summary-active">
                    <MudText Typo="Typo.caption" Class="dashboard-summary-label">Activos</MudText>
                    <MudText Typo="Typo.h4" Class="dashboard-summary-value">@ViewModel.TotalActivos</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" lg="2">
                <MudPaper Elevation="1" Class="pa-4 dashboard-summary summary-inactive">
                    <MudText Typo="Typo.caption" Class="dashboard-summary-label">Inactivos</MudText>
                    <MudText Typo="Typo.h4" Class="dashboard-summary-value">@ViewModel.TotalInactivos</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Elevation="1" Class="pa-4 dashboard-filter-card dashboard-panel">
            <MudGrid Spacing="2" Class="dashboard-filter-grid">
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="ViewModel.SearchText"
                                  Label="Buscar"
                                  Placeholder="Nombre, documento, celular, email, código, estado o tipo"
                                  Variant="Variant.Outlined"
                                  Immediate="true"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="string" @bind-Value="ViewModel.EstadoFiltro"
                               Label="Estado"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Todos")">Todos</MudSelectItem>
                        <MudSelectItem Value="@("Activos")">Activos</MudSelectItem>
                        <MudSelectItem Value="@("Inactivos")">Inactivos</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="string" @bind-Value="ViewModel.TipoFiltro"
                               Label="Tipo de referido"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Todos")">Todos</MudSelectItem>
                        <MudSelectItem Value="@("Directo")">Directo</MudSelectItem>
                        <MudSelectItem Value="@("Indirecto")">Indirecto</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Elevation="1" Class="dashboard-table-card dashboard-panel">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="dashboard-table-toolbar">
                <div>
                    <MudText Typo="Typo.subtitle1" Class="dashboard-card-title">Red de referidos</MudText>
                    <MudText Typo="Typo.caption" Class="dashboard-card-caption">
                        Datos filtrados actualmente en el Dashboard.
                    </MudText>
                </div>
                @if (ViewModel.IsAdmin)
                {
                    <MudButton Color="Color.Primary"
                               Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.FileDownload"
                               Disabled="@ViewModel.IsBusy"
                               OnClick="ExportDashboardToExcelAsync"
                               Class="dashboard-export-button">
                        Exportar Excel
                    </MudButton>
                }
            </MudStack>
            <MudTable Items="@ViewModel.ObtenerReferidosFiltrados()"
                      Hover="true"
                      Dense="true"
                      Breakpoint="Breakpoint.Md"
                      Loading="@ViewModel.IsBusy"
                      Elevation="0"
                      Class="dashboard-table">
                <HeaderContent>
                    <MudTh>Simpatizante</MudTh>
                    <MudTh>Contacto</MudTh>
                    <MudTh>Codigo</MudTh>
                    <MudTh>Referidor</MudTh>
                    <MudTh>Registro</MudTh>
                    <MudTh>Estado</MudTh>
                    <MudTh>Tipo</MudTh>
                    <MudTh>Acciones</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Simpatizante">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.subtitle2">@context.NombresCompletos</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.NumeroIdentificacion</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Contacto">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@Display(context.Email)</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Display(context.Celular)</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Codigo">
                        <MudText Typo="Typo.body2">@context.CodigoReferido</MudText>
                    </MudTd>
                    <MudTd DataLabel="Referidor">@Display(context.Referidor)</MudTd>
                    <MudTd DataLabel="Registro">@context.FechaRegistro.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd DataLabel="Estado">
                        <MudChip T="string"
                                 Color="@(context.Estado ? Color.Success : Color.Default)"
                                 Variant="Variant.Filled"
                                 Size="Size.Small">
                            @(context.Estado ? "Activo" : "Inactivo")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Tipo">
                        <MudChip T="string"
                                 Color="@(context.Nivel == 1 ? Color.Primary : Color.Info)"
                                 Variant="Variant.Outlined"
                                 Size="Size.Small">
                            @context.TipoReferido
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Acciones">
                        <MudStack Row="true" Spacing="1">
                            <MudTooltip Text="Copiar enlace de referido">
                                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               OnClick="@(() => CopyReferralUrlAsync(context))" />
                            </MudTooltip>
                            <MudTooltip Text="Desactivar referido">
                                <MudIconButton Icon="@Icons.Material.Filled.Block"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               Disabled="@(!context.Estado || ViewModel.IsBusy)"
                                               OnClick="@(() => DeactivateAsync(context))" />
                            </MudTooltip>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">
                        No hay referidos que coincidan con los filtros.
                    </MudText>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>
        </MudStack>
    </div>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await ViewModel.InitializeAsync();
        if (!ViewModel.IsAuthenticated)
        {
            Navigation.NavigateTo(AppRoutes.Login, replace: true);
        }
    }

    private async Task ReloadAsync()
    {
        await ViewModel.CargarReferidosAsync();
    }

    private async Task CopyReferralUrlAsync(CiudadanoReferidoModel referido)
    {
        var url = ViewModel.BuildReferralUrl(referido.CodigoReferido);
        await JSRuntime.InvokeVoidAsync("RedVictoriaSweetAlert.copyText", url);
    }

    private async Task CopyOwnReferralUrlAsync()
    {
        if (string.IsNullOrWhiteSpace(ViewModel.MiUrlReferido))
        {
            await JSRuntime.InvokeVoidAsync(
                "RedVictoriaSweetAlert.fire",
                "error",
                "No fue posible copiar",
                "No encontramos tu código referido en la sesión actual. Inicia sesión nuevamente.");
            return;
        }

        await JSRuntime.InvokeVoidAsync("RedVictoriaSweetAlert.copyText", ViewModel.MiUrlReferido);
    }

    private async Task DeactivateAsync(CiudadanoReferidoModel referido)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "RedVictoriaSweetAlert.confirmDeactivate",
            referido.NombresCompletos);
        if (!confirmed)
        {
            return;
        }

        var success = await ViewModel.DesactivarReferidoAsync(referido);
        if (success)
        {
            await JSRuntime.InvokeVoidAsync(
                "RedVictoriaSweetAlert.fire",
                "success",
                "Referido desactivado",
                "El referido fue desactivado correctamente.");
            return;
        }

        await JSRuntime.InvokeVoidAsync(
            "RedVictoriaSweetAlert.fire",
            "error",
            "No fue posible desactivar",
            ViewModel.ErrorMessage ?? "No fue posible desactivar el referido.");
    }

    private async Task ExportDashboardToExcelAsync()
    {
        var excelBytes = DashboardExcelExporter.Export(ViewModel.ObtenerReferidosFiltrados());
        await JSRuntime.InvokeVoidAsync(
            "RedVictoriaFileDownload.downloadBase64File",
            "Dashboard_RedVictoria.xlsx",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            Convert.ToBase64String(excelBytes));
    }

    private static string Display(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;
}
