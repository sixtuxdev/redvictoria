@page "/dashboard"
@using RedVictoria.WebUI.Helpers
@inject DashboardViewModel ViewModel
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<PageTitle>Dashboard</PageTitle>

@if (ViewModel.IsLoading)
{
    <div class="dashboard-loading">
        <MudStack AlignItems="AlignItems.Center" Class="py-10">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">Cargando dashboard...</MudText>
        </MudStack>
    </div>
}
else
{
    <div class="dashboard-page">
        <MudStack Spacing="5" Class="dashboard-content">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="dashboard-header dashboard-hero">
                <div class="dashboard-heading">
                    <MudImage Src="image/logo.png"
                              Alt="RedVictoria"
                              Class="dashboard-logo" />
                    <div class="dashboard-heading-text">
                        <MudText Typo="Typo.h4" Class="dashboard-title">Dashboard</MudText>
                        <MudText Typo="Typo.body2" Class="dashboard-subtitle">
                            Hola, @ViewModel.Session?.Nombre. Esta es la actividad de tu red de simpatizantes.
                        </MudText>
                    </div>
                </div>
                <MudButton Color="Color.Primary"
                           Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           Disabled="@ViewModel.IsBusy"
                           OnClick="ReloadAsync"
                           Class="dashboard-refresh-button">
                    Actualizar
                </MudButton>
            </MudStack>

        @if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="dashboard-alert">
                @ViewModel.ErrorMessage
            </MudAlert>
        }

        <MudGrid Spacing="3" Class="dashboard-summary-grid">
            <MudItem xs="12" lg="4">
                <MudPaper Elevation="1" Class="pa-4 own-referral-card dashboard-panel">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Class="dashboard-card-avatar">
                                <MudIcon Icon="@Icons.Material.Filled.Share" />
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle1" Class="dashboard-card-title">Comparte tu referido</MudText>
                                <MudText Typo="Typo.caption" Class="dashboard-card-caption">
                                    Invita nuevos simpatizantes bajo tu red.
                                </MudText>
                            </div>
                        </MudStack>

                        <MudText Typo="Typo.body2" Class="own-referral-url">
                            @Display(ViewModel.MiUrlReferido)
                        </MudText>

                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Filled.ContentCopy"
                                   Disabled="@string.IsNullOrWhiteSpace(ViewModel.MiUrlReferido)"
                                   OnClick="CopiarEnlaceReferido"
                                   Class="dashboard-primary-action">
                            Copiar mi enlace de referido
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" lg="2">
                <MudPaper Elevation="1" Class="pa-4 dashboard-summary summary-direct">
                    <MudText Typo="Typo.caption" Class="dashboard-summary-label">Referidos directos</MudText>
                    <MudText Typo="Typo.h4" Class="dashboard-summary-value">@ViewModel.TotalDirectos</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" lg="2">
                <MudPaper Elevation="1" Class="pa-4 dashboard-summary summary-indirect">
                    <MudText Typo="Typo.caption" Class="dashboard-summary-label">Referidos indirectos</MudText>
                    <MudText Typo="Typo.h4" Class="dashboard-summary-value">@ViewModel.TotalIndirectos</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" lg="2">
                <MudPaper Elevation="1" Class="pa-4 dashboard-summary summary-active">
                    <MudText Typo="Typo.caption" Class="dashboard-summary-label">Activos</MudText>
                    <MudText Typo="Typo.h4" Class="dashboard-summary-value">@ViewModel.TotalActivos</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" lg="2">
                <MudPaper Elevation="1" Class="pa-4 dashboard-summary summary-inactive">
                    <MudText Typo="Typo.caption" Class="dashboard-summary-label">Inactivos</MudText>
                    <MudText Typo="Typo.h4" Class="dashboard-summary-value">@ViewModel.TotalInactivos</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Elevation="1" Class="pa-4 dashboard-filter-card dashboard-panel">
            <MudGrid Spacing="2" Class="dashboard-filter-grid">
                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Value="@ViewModel.SearchText"
                                  ValueChanged="OnSearchChanged"
                                  Label="Buscar"
                                  Placeholder="Nombre, documento, celular, email, código, estado o tipo"
                                  Variant="Variant.Outlined"
                                  Immediate="true"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="string"
                               Value="@ViewModel.EstadoFiltro"
                               ValueChanged="OnEstadoFiltroChanged"
                               Label="Estado"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Todos")">Todos</MudSelectItem>
                        <MudSelectItem Value="@("Activos")">Activos</MudSelectItem>
                        <MudSelectItem Value="@("Inactivos")">Inactivos</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="string"
                               Value="@ViewModel.TipoFiltro"
                               ValueChanged="OnTipoFiltroChanged"
                               Label="Tipo de referido"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Todos")">Todos</MudSelectItem>
                        <MudSelectItem Value="@("Directo")">Directo</MudSelectItem>
                        <MudSelectItem Value="@("Indirecto")">Indirecto</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Elevation="1" Class="dashboard-table-card dashboard-panel">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="dashboard-table-toolbar">
                <div>
                    <MudText Typo="Typo.subtitle1" Class="dashboard-card-title">Red de referidos</MudText>
                    <MudText Typo="Typo.caption" Class="dashboard-card-caption">
                        Datos filtrados actualmente en el Dashboard.
                    </MudText>
                </div>
                @if (ViewModel.IsAdmin)
                {
                    <MudButton Color="Color.Primary"
                               Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.FileDownload"
                               Disabled="@ViewModel.IsBusy"
                               OnClick="ExportDashboardToExcelAsync"
                               Class="dashboard-export-button">
                        Exportar Excel
                    </MudButton>
                }
            </MudStack>
            <MudDataGrid @ref="referidosGrid"
                         T="CiudadanoReferidoModel"
                         ServerData="LoadReferidosServerData"
                         Hover="true"
                         Dense="true"
                         Breakpoint="Breakpoint.Md"
                         Elevation="0"
                         Class="dashboard-table"
                         Filterable="true"
                         FilterMode="DataGridFilterMode.ColumnFilterMenu"
                         SortMode="SortMode.Single"
                         RowsPerPage="10">
                <Columns>
                    <PropertyColumn Property="item => item.NombresCompletos" Title="Simpatizante">
                        <CellTemplate Context="cellContext">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.subtitle2">@cellContext.Item.NombresCompletos</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@cellContext.Item.NumeroIdentificacion</MudText>
                            </MudStack>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="item => item.Email" Title="Contacto">
                        <CellTemplate Context="cellContext">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2">@Display(cellContext.Item.Email)</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@Display(cellContext.Item.Celular)</MudText>
                            </MudStack>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="item => item.FechaNacimiento" Title="Fecha de nacimiento" Format="dd/MM/yyyy" />
                    <PropertyColumn Property="item => item.CodigoReferido" Title="Código" />
                    <PropertyColumn Property="item => item.Referidor" Title="Referidor" />
                    <PropertyColumn Property="item => item.FechaRegistro" Title="Registro" Format="yyyy-MM-dd" />
                    <PropertyColumn Property="item => item.Estado" Title="Estado">
                        <CellTemplate Context="cellContext">
                            <MudChip T="string"
                                     Color="@(cellContext.Item.Estado ? Color.Success : Color.Default)"
                                     Variant="Variant.Filled"
                                     Size="Size.Small">
                                @(cellContext.Item.Estado ? "Activo" : "Inactivo")
                            </MudChip>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="item => item.TipoReferido" Title="Tipo">
                        <CellTemplate Context="cellContext">
                            <MudChip T="string"
                                     Color="@(cellContext.Item.Nivel == 1 ? Color.Primary : Color.Info)"
                                     Variant="Variant.Outlined"
                                     Size="Size.Small">
                                @cellContext.Item.TipoReferido
                            </MudChip>
                        </CellTemplate>
                    </PropertyColumn>
                    <TemplateColumn Title="Acciones" Sortable="false" Filterable="false">
                        <CellTemplate Context="cellContext">
                            <MudStack Row="true" Spacing="1">
                                <MudTooltip Text="Copiar enlace de referido">
                                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   OnClick="@(() => CopyReferralUrlAsync(cellContext.Item))" />
                                </MudTooltip>
                                <MudTooltip Text="Desactivar referido">
                                    <MudIconButton Icon="@Icons.Material.Filled.Block"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   Disabled="@(!cellContext.Item.Estado || ViewModel.IsBusy)"
                                                   OnClick="@(() => DeactivateAsync(cellContext.Item))" />
                                </MudTooltip>
                            </MudStack>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">
                        No hay referidos que coincidan con los filtros.
                    </MudText>
                </NoRecordsContent>
                <PagerContent>
                    <MudDataGridPager T="CiudadanoReferidoModel"
                                      PageSizeOptions="new[] { 10, 25, 50 }"
                                      RowsPerPageString="Registros por página"
                                      InfoFormat="{first_item}-{last_item} de {all_items}" />
                </PagerContent>
            </MudDataGrid>
        </MudPaper>
        </MudStack>
    </div>
}

@code {
    private MudDataGrid<CiudadanoReferidoModel>? referidosGrid;

    protected override async Task OnInitializedAsync()
    {
        await ViewModel.InitializeAsync();
        if (!ViewModel.IsAuthenticated)
        {
            Navigation.NavigateTo(AppRoutes.Login, replace: true);
        }
    }

    private async Task ReloadAsync()
    {
        if (referidosGrid is not null)
        {
            await referidosGrid.ReloadServerData();
        }
    }

    private async Task<GridData<CiudadanoReferidoModel>> LoadReferidosServerData(
        GridState<CiudadanoReferidoModel> state)
    {
        var data = await ViewModel.ObtenerReferidosGridAsync(state);
        await InvokeAsync(StateHasChanged);
        return data;
    }

    private async Task OnSearchChanged(string value)
    {
        ViewModel.SearchText = value ?? string.Empty;
        await ReloadFromFirstPageAsync();
    }

    private async Task OnEstadoFiltroChanged(string value)
    {
        ViewModel.EstadoFiltro = value;
        await ReloadFromFirstPageAsync();
    }

    private async Task OnTipoFiltroChanged(string value)
    {
        ViewModel.TipoFiltro = value;
        await ReloadFromFirstPageAsync();
    }

    private async Task ReloadFromFirstPageAsync()
    {
        if (referidosGrid is null)
        {
            return;
        }

        referidosGrid.NavigateTo(Page.First);
        await referidosGrid.ReloadServerData();
    }

    private async Task CopyReferralUrlAsync(CiudadanoReferidoModel referido)
    {
        var url = ViewModel.BuildReferralUrl(referido.CodigoReferido);
        await CopyReferralUrlToClipboardAsync(url);
    }

    private async Task CopiarEnlaceReferido()
    {
        if (string.IsNullOrWhiteSpace(ViewModel.MiUrlReferido))
        {
            Snackbar.Add("No se encontró el enlace de referido.", Severity.Warning);
            return;
        }

        await CopyReferralUrlToClipboardAsync(ViewModel.MiUrlReferido);
    }

    private async Task CopyReferralUrlToClipboardAsync(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            Snackbar.Add("No se encontró el enlace de referido.", Severity.Warning);
            return;
        }

        var copiado = await JSRuntime.InvokeAsync<bool>(
            "redVictoria.copyToClipboard",
            url);

        if (copiado)
        {
            Snackbar.Add("Enlace de referido copiado correctamente.", Severity.Success);
        }
        else
        {
            Snackbar.Add("No se pudo copiar el enlace. Puedes seleccionarlo manualmente.", Severity.Error);
        }
    }

    private async Task DeactivateAsync(CiudadanoReferidoModel referido)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "RedVictoriaSweetAlert.confirmDeactivate",
            referido.NombresCompletos);
        if (!confirmed)
        {
            return;
        }

        var success = await ViewModel.DesactivarReferidoAsync(referido);
        if (success)
        {
            await ReloadAsync();
            await JSRuntime.InvokeVoidAsync(
                "RedVictoriaSweetAlert.fire",
                "success",
                "Referido desactivado",
                "El referido fue desactivado correctamente.");
            return;
        }

        await JSRuntime.InvokeVoidAsync(
            "RedVictoriaSweetAlert.fire",
            "error",
            "No fue posible desactivar",
            ViewModel.ErrorMessage ?? "No fue posible desactivar el referido.");
    }

    private async Task ExportDashboardToExcelAsync()
    {
        try
        {
            var excelBytes = await ViewModel.ExportarReferidosExcelAsync();
            if (excelBytes == null || excelBytes.Length == 0)
            {
                await JSRuntime.InvokeVoidAsync(
                    "RedVictoriaSweetAlert.fire",
                    "error",
                    "Exportación fallida",
                    "No fue posible generar el archivo Excel o no hay datos para exportar.");
                return;
            }

            await JSRuntime.InvokeVoidAsync(
                "RedVictoriaFileDownload.downloadBase64File",
                "RedReferidos.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                Convert.ToBase64String(excelBytes));
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync(
                "RedVictoriaSweetAlert.fire",
                "error",
                "Error de exportación",
                "Ocurrió un error al descargar el archivo: " + ex.Message);
        }
    }

    private static string Display(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;
}
