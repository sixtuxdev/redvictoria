@page "/login"
@layout LoginLayout
@inject LoginViewModel ViewModel
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Iniciar sesión</PageTitle>

<div class="login-page">
    <div class="login-background login-background-one"></div>
    <div class="login-background login-background-two"></div>

    <MudPaper Elevation="12" Class="login-card">
        <div class="login-left-panel">
            <div class="login-left-content">
                <MudAvatar Color="Color.Default" Variant="Variant.Filled" Size="Size.Large" Class="login-brand-avatar">
                    <MudIcon Icon="@Icons.Material.Filled.HowToVote" Size="Size.Medium" />
                </MudAvatar>

                <MudText Typo="Typo.h3" Align="Align.Center" Class="login-brand-title">
                    El Equipo Ganador
                </MudText>

                <MudText Typo="Typo.body1" Align="Align.Center" Class="login-brand-description">
                    Gestiona tu red de referidos, consulta tus simpatizantes y fortalece la participación ciudadana.
                </MudText>

                <div class="login-info-card">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Class="login-info-icon" />
                    <MudText Typo="Typo.body2" Class="login-info-text">
                        Construyendo comunidad con organización, liderazgo y participación.
                    </MudText>
                </div>
            </div>

            <div class="login-wave"></div>
        </div>

        <div class="login-right-panel">
            <div class="login-form-wrapper">
                <MudStack Spacing="5">
                    <MudStack Spacing="2" AlignItems="AlignItems.Center" Class="login-heading">
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" Class="login-avatar">
                            <MudIcon Icon="@Icons.Material.Filled.LockOpen" Size="Size.Medium" />
                        </MudAvatar>

                        <MudText Typo="Typo.h4" Align="Align.Center" Class="login-title">
                            Iniciar sesión
                        </MudText>

                        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary" Class="login-subtitle">
                            Accede a el equipo ganador para consultar tu red de referidos y gestionar tu participación ciudadana.
                        </MudText>
                    </MudStack>

                    @if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
                    {
                        <MudAlert Severity="Severity.Error"
                                  Variant="Variant.Filled"
                                  Dense="true"
                                  Class="login-alert">
                            @ViewModel.ErrorMessage
                        </MudAlert>
                    }

                    <MudForm @ref="_form" Model="@ViewModel.Request" @onsubmit="HandleLoginAsync" Class="login-form">
                        <MudStack Spacing="4">
                            <MudTextField @bind-Value="ViewModel.Request.UserIdentifier"
                                          Label="Usuario, correo o documento"
                                          Variant="Variant.Outlined"
                                          Immediate="true"
                                          Required="true"
                                          RequiredError="Ingresa tu usuario, correo o documento."
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Person"
                                          Disabled="@ViewModel.IsBusy"
                                          Class="login-field" />

                            <MudTextField @bind-Value="ViewModel.Request.Password"
                                          Label="Contraseña"
                                          Variant="Variant.Outlined"
                                          InputType="@PasswordInputType"
                                          Immediate="true"
                                          Required="true"
                                          RequiredError="Ingresa tu contraseña."
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@PasswordAdornmentIcon"
                                          OnAdornmentClick="TogglePasswordVisibility"
                                          AdornmentAriaLabel="@PasswordAdornmentLabel"
                                          Disabled="@ViewModel.IsBusy"
                                          Class="login-field" />

                            <MudButton ButtonType="ButtonType.Submit"
                                       Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       Size="Size.Large"
                                       FullWidth="true"
                                       Disabled="@ViewModel.IsBusy"
                                       Class="login-submit">
                                @if (ViewModel.IsBusy)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <span>Validando...</span>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Login" Class="mr-2" />
                                    <span>Iniciar sesión</span>
                                }
                            </MudButton>
                        </MudStack>
                    </MudForm>

                    <AuthLinks />
                </MudStack>
            </div>
        </div>
    </MudPaper>
</div>

@code {
    private MudForm? _form;
    private bool _showPassword;

    private InputType PasswordInputType => _showPassword ? InputType.Text : InputType.Password;

    private string PasswordAdornmentIcon => _showPassword
        ? Icons.Material.Filled.VisibilityOff
        : Icons.Material.Filled.Visibility;

    private string PasswordAdornmentLabel => _showPassword
        ? "Ocultar contraseña"
        : "Mostrar contraseña";

    private async Task HandleLoginAsync()
    {
        if (ViewModel.IsBusy)
        {
            return;
        }

        if (_form is not null)
        {
            await _form.Validate();
            if (!_form.IsValid)
            {
                return;
            }
        }

        var loggedIn = await ViewModel.LoginAsync();

        if (!loggedIn)
        {
            return;
        }

        Snackbar.Add(ViewModel.SuccessMessage ?? "Inicio de sesión exitoso.", Severity.Success);
        await InvokeAsync(() => Navigation.NavigateTo(AppRoutes.Dashboard, replace: true));
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }
}
